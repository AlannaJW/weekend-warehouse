# Copy this file to ~/.dbt/profiles.yml and fill in your own values.
# Do NOT commit your real profiles.yml — it points at a credentials file
# and may contain project IDs you don't want public.

weekend_warehouse:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: YOUR-GCP-PROJECT-ID            # e.g. weekend-warehouse-123456
      dataset: marts                          # default schema for marts/* models
      keyfile: /absolute/path/to/service-account-key.json
      threads: 4
      location: US                            # match the location of your raw dataset
      timeout_seconds: 300
      priority: interactive
      retries: 1
